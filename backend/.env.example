# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DJANGO_SECRET_KEY=django-insecure-local-dev-key-12345
OPENROUTER_API_KEY=
DECOMPOSER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# Sprint 4: Lesson skills — use the same model ID as DECOMPOSER_MODEL for now.
# These can be changed independently in the future to route to different models.
LESSON_GENERATOR_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
SOCRATIC_TUTOR_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

DB_SSLMODE=require
# Optional. If unset, fallback is enabled only when DJANGO_DEBUG=true.
# For non-dev environments, prefer false.
AUTH_STUB_ALLOW_FIREBASE_FALLBACK=true
